{
  "kind": "collectionType",
  "collectionName": "activities",
  "info": {
    "singularName": "activity",
    "pluralName": "activities",
    "displayName": "Activity"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "title_en": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "description_en": {
      "type": "blocks"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "conference",
        "workshop",
        "seminar"
      ]
    },
    "event_status": {
      "type": "enumeration",
      "enum": [
        "open",
        "register",
        "upcoming",
        "finished"
      ]
    },
    "location": {
      "type": "string"
    },
    "location_en": {
      "type": "string"
    },
    "event_start_date": {
      "type": "date"
    },
    "event_end_date": {
      "type": "date"
    },
    "year": {
      "type": "integer"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "deadline": {
      "type": "component",
      "component": "deadline.deadline-item",
      "repeatable": true
    },
    "buttons": {
      "type": "component",
      "component": "ui.button-item",
      "repeatable": true
    }
  }
}
